{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Karate: Run All API Tests",
      "type": "shell",
      "command": "mvn test",
      "options": {
        "cwd": "${workspaceFolder}/karate",
        "env": { "JAVA_HOME": "C:\\Program Files\\Java\\jdk-21.0.11" }
      },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
